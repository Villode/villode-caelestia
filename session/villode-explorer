#!/usr/bin/env python3
"""Launch a system file manager (Caelestia default-app setting, else PATH probe)."""

import json
import os
import shutil
from pathlib import Path

SELF_NAMES = {"villode-explorer"}


def configured_explorer():
    config_home = Path(os.environ.get("XDG_CONFIG_HOME", Path.home() / ".config"))
    try:
        data = json.loads((config_home / "caelestia" / "shell.json").read_text())
        command = data["general"]["apps"]["explorer"]
        if (
            isinstance(command, list)
            and command
            and all(isinstance(argument, str) and argument for argument in command)
            and Path(command[0]).name not in SELF_NAMES
            and shutil.which(command[0])
        ):
            return command
    except (FileNotFoundError, KeyError, OSError, TypeError, ValueError, json.JSONDecodeError):
        pass

    for candidate in ("nautilus", "dolphin", "thunar", "nemo", "pcmanfm", "caja", "cosmic-files"):
        if shutil.which(candidate):
            return [candidate]
    # Last resort: let the desktop portal / mime system pick something.
    if shutil.which("xdg-open"):
        return ["xdg-open", str(Path.home())]
    raise SystemExit("No supported file manager is installed.")


os.execvp((command := configured_explorer())[0], command)
