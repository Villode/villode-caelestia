[Unit]
Description=Villode FileManager1 (org.freedesktop.FileManager1)
Documentation=man:dbus-daemon(1)
After=graphical-session.target
PartOf=graphical-session.target

[Service]
Type=dbus
BusName=org.freedesktop.FileManager1
ExecStart=%h/.local/bin/villode-filemanager1
Restart=on-failure
RestartSec=1

[Install]
WantedBy=default.target
