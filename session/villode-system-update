#!/usr/bin/env bash
# Check / run Arch system package upgrades for Villode settings UI.
# Separate from villode-caelestia-update (component channel).
# - check / check-json: read-only
# - apply: interactive terminal (legacy)
# - apply --yes / --apply-ui: noninteractive for Settings dialog (pkexec + --noconfirm)
set -euo pipefail

usage() {
    cat <<'EOF'
用法 / Usage：villode-system-update [--check|--check-json|--apply] [--yes]

  --check       列出可升级系统包（制表符：name old new）
  --check-json  JSON（供设置页）
  --apply       交互式执行 pacman -Syu（终端确认 + sudo）
  --apply --yes 非交互：pkexec pacman -Syu --noconfirm（设置弹窗）

说明：系统滚动更新，不是 Villode 组件更新。
EOF
}

mode=check-json
yes=0
while (($#)); do
    case "$1" in
        --check) mode=check ;;
        --check-json) mode=check-json ;;
        --apply) mode=apply ;;
        --apply-ui) mode=apply; yes=1 ;;
        --yes|-y) yes=1 ;;
        -h|--help) usage; exit 0 ;;
        *) usage >&2; exit 64 ;;
    esac
    shift
done

collect_upgrades() {
    packages=()
    if command -v checkupdates >/dev/null 2>&1; then
        while IFS= read -r line; do
            [[ -z "$line" ]] && continue
            if [[ "$line" =~ ^([^[:space:]]+)[[:space:]]+([^[:space:]]+)[[:space:]]+\-\>[[:space:]]+([^[:space:]]+) ]]; then
                packages+=("${BASH_REMATCH[1]}"$'\t'"${BASH_REMATCH[2]}"$'\t'"${BASH_REMATCH[3]}")
            fi
        done < <(checkupdates 2>/dev/null || true)
    fi
    if ((${#packages[@]} == 0)) && command -v pacman >/dev/null 2>&1; then
        while IFS= read -r line; do
            [[ -z "$line" ]] && continue
            if [[ "$line" =~ ^([^[:space:]]+)[[:space:]]+([^[:space:]]+)[[:space:]]+\-\>[[:space:]]+([^[:space:]]+) ]]; then
                packages+=("${BASH_REMATCH[1]}"$'\t'"${BASH_REMATCH[2]}"$'\t'"${BASH_REMATCH[3]}")
            fi
        done < <(pacman -Qu 2>/dev/null || true)
    fi
}

run_pacman_syu() {
    echo "VILLODE_PROGRESS phase=upgrade"
    if [[ "$(id -u)" -eq 0 ]]; then
        if command -v stdbuf >/dev/null 2>&1; then
            stdbuf -oL -eL pacman -Syu --noconfirm --color never
        else
            pacman -Syu --noconfirm --color never
        fi
        return $?
    fi
    if command -v pkexec >/dev/null 2>&1; then
        echo "VILLODE_PROGRESS phase=auth"
        # polkit agent prompts; keep pacman line-buffered when possible
        if command -v stdbuf >/dev/null 2>&1; then
            pkexec env PATH="/usr/local/sbin:/usr/local/bin:/usr/bin" \
                stdbuf -oL -eL pacman -Syu --noconfirm --color never
        else
            pkexec env PATH="/usr/local/sbin:/usr/local/bin:/usr/bin" \
                pacman -Syu --noconfirm --color never
        fi
        return $?
    fi
    echo "VILLODE_PROGRESS phase=auth"
    if command -v stdbuf >/dev/null 2>&1; then
        sudo stdbuf -oL -eL pacman -Syu --noconfirm --color never
    else
        sudo pacman -Syu --noconfirm --color never
    fi
}

if [[ "$mode" == apply ]]; then
    if ! command -v pacman >/dev/null 2>&1; then
        echo "未找到 pacman。此功能仅适用于 Arch / CachyOS 等。" >&2
        exit 69
    fi

    if [[ "$yes" -eq 1 ]]; then
        echo "VILLODE_PROGRESS phase=start"
        echo "Starting system upgrade (pacman -Syu --noconfirm)…"
        collect_upgrades
        if ((${#packages[@]} > 0)); then
            echo "VILLODE_PROGRESS phase=list count=${#packages[@]}"
            echo "Packages to upgrade: ${#packages[@]}"
        else
            echo "VILLODE_PROGRESS phase=list count=0"
            echo "No pending packages in check cache; still running -Syu to sync."
        fi
        set +e
        run_pacman_syu
        code=$?
        set -e
        if [[ $code -eq 0 ]]; then
            echo "VILLODE_PROGRESS phase=done"
            echo "System upgrade finished."
        else
            echo "VILLODE_PROGRESS phase=failed code=$code"
            echo "System upgrade failed, exit $code" >&2
        fi
        exit "$code"
    fi

    zh=0
    case "${LANG:-}" in zh*|zh_*) zh=1 ;; esac
    echo
    if [[ "$zh" == 1 ]]; then
        echo "════════════════════════════════════════"
        echo "  系统软件包更新（Arch 滚动）"
        echo "════════════════════════════════════════"
        echo
        echo "将执行：sudo pacman -Syu"
        echo "可能更新：内核、驱动、桌面库、浏览器等全部过期软件包。"
        echo "这与「Villode 组件更新」无关。"
        echo "风险：滚动更新偶发异常，请先查看列表再确认。"
    else
        echo "════════════════════════════════════════"
        echo "  System package upgrade (Arch rolling)"
        echo "════════════════════════════════════════"
        echo
        echo "Will run: sudo pacman -Syu"
        echo "May upgrade: kernel, drivers, libs, browsers — all outdated packages."
        echo "This is NOT the Villode component channel."
        echo "Risk: rolling upgrades can break systems. Review the list first."
    fi
    echo
    collect_upgrades
    if ((${#packages[@]} == 0)); then
        echo "正在同步软件库并检查（可能需要网络）…"
        sudo pacman -Sy
        collect_upgrades
    fi
    if ((${#packages[@]} == 0)); then
        echo "系统软件包已是最新（或无法检查到更新）。"
        read -r -p "仍要运行 sudo pacman -Syu 吗？[y/N] / Run -Syu anyway? [y/N] " ans || ans=n
        [[ "$ans" == y || "$ans" == Y ]] || exit 0
    else
        echo "将升级 ${#packages[@]} 个软件包 / packages to upgrade："
        echo
        printf '  %-36s %s → %s\n' "包名 / package" "当前 / old" "新 / new"
        for local_line in "${packages[@]}"; do
            IFS=$'\t' read -r name old new <<<"$local_line"
            printf '  %-36s %s → %s\n' "$name" "$old" "$new"
        done | head -n 80
        if ((${#packages[@]} > 80)); then
            echo "  … 另有 $((${#packages[@]} - 80)) 个未列出 / more not shown"
        fi
        echo
        read -r -p "确认执行系统滚动更新？[y/N] / Proceed with full system upgrade? [y/N] " ans || ans=n
        [[ "$ans" == y || "$ans" == Y ]] || { echo "已取消 / Cancelled."; exit 0; }
    fi
    echo
    sudo pacman -Syu
    code=$?
    echo
    if [[ $code -eq 0 ]]; then
        echo "系统更新完成 / System upgrade finished."
    else
        echo "系统更新失败，退出码 $code / Upgrade failed, exit $code" >&2
    fi
    exit "$code"
fi

collect_upgrades
if [[ "$mode" == check ]]; then
    for line in "${packages[@]+"${packages[@]}"}"; do
        printf '%s\n' "$line"
    done
    exit 0
fi

tmp="$(mktemp)"
if ((${#packages[@]})); then
    printf '%s\n' "${packages[@]}" >"$tmp"
else
    : >"$tmp"
fi
python3 - "$tmp" <<'PY'
import json, sys
from datetime import datetime
from pathlib import Path

path = Path(sys.argv[1])
packages = []
for line in path.read_text(encoding="utf-8").splitlines():
    line = line.strip()
    if not line:
        continue
    parts = line.split("\t")
    while len(parts) < 3:
        parts.append("")
    name, old, new = parts[0], parts[1], parts[2]
    packages.append({"name": name, "old": old, "new": new})

risky_keywords = (
    "linux", "nvidia", "mesa", "systemd", "glibc", "gcc", "llvm",
    "hyprland", "qt6", "gtk4", "pipewire", "amd-ucode", "intel-ucode",
)
risky = []
for p in packages:
    n = p["name"].lower()
    if any(k in n for k in risky_keywords):
        risky.append(p["name"])

out = {
    "checkedAt": datetime.now().astimezone().isoformat(timespec="seconds"),
    "packageCount": len(packages),
    "packages": packages[:200],
    "truncated": len(packages) > 200,
    "riskyPackages": risky[:40],
    "kind": "system",
    "summary": (
        f"{len(packages)} system package(s) can be upgraded (Arch rolling: pacman -Syu)"
        if packages
        else "System packages appear up to date"
    ),
    "summaryZh": (
        f"有 {len(packages)} 个系统软件包可升级（Arch 滚动：pacman -Syu）"
        if packages
        else "系统软件包已是最新"
    ),
    "warning": (
        "Full system upgrade may include kernel/drivers/libraries. "
        "This is separate from Villode components. Review the list before applying."
    ),
    "warningZh": (
        "完整系统更新可能包含内核、驱动与基础库，与 Villode 组件更新无关。"
        "请先查看列表再确认执行。"
    ),
    "command": "pkexec pacman -Syu --noconfirm",
}
print(json.dumps(out, ensure_ascii=False, indent=2))
PY
rm -f "$tmp"
