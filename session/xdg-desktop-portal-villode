#!/usr/bin/env python3
"""Villode FileChooser portal backend.

Implements org.freedesktop.impl.portal.FileChooser by opening the Caelestia
QML picker via `qs -c caelestia ipc call filechooser request <json>` and waiting
for a result file written by PortalPicker.qml.

DBus name: org.freedesktop.impl.portal.desktop.villode
"""

from __future__ import annotations

import json
import os
import signal
import subprocess
import sys
import tempfile
import threading
import time
import urllib.parse
from pathlib import Path

import gi

gi.require_version("Gio", "2.0")
gi.require_version("GLib", "2.0")
from gi.repository import Gio, GLib  # noqa: E402

BUS_NAME = "org.freedesktop.impl.portal.desktop.villode"
OBJECT_PATH = "/org/freedesktop/portal/desktop"
IFACE = "org.freedesktop.impl.portal.FileChooser"
TIMEOUT_SEC = 600

INTROSPECTION_XML = f"""
<node>
  <interface name="{IFACE}">
    <method name="OpenFile">
      <arg type="o" name="handle" direction="in"/>
      <arg type="s" name="app_id" direction="in"/>
      <arg type="s" name="parent_window" direction="in"/>
      <arg type="s" name="title" direction="in"/>
      <arg type="a{{sv}}" name="options" direction="in"/>
      <arg type="u" name="response" direction="out"/>
      <arg type="a{{sv}}" name="results" direction="out"/>
    </method>
    <method name="SaveFile">
      <arg type="o" name="handle" direction="in"/>
      <arg type="s" name="app_id" direction="in"/>
      <arg type="s" name="parent_window" direction="in"/>
      <arg type="s" name="title" direction="in"/>
      <arg type="a{{sv}}" name="options" direction="in"/>
      <arg type="u" name="response" direction="out"/>
      <arg type="a{{sv}}" name="results" direction="out"/>
    </method>
    <method name="SaveFiles">
      <arg type="o" name="handle" direction="in"/>
      <arg type="s" name="app_id" direction="in"/>
      <arg type="s" name="parent_window" direction="in"/>
      <arg type="s" name="title" direction="in"/>
      <arg type="a{{sv}}" name="options" direction="in"/>
      <arg type="u" name="response" direction="out"/>
      <arg type="a{{sv}}" name="results" direction="out"/>
    </method>
  </interface>
</node>
"""


def log(msg: str) -> None:
    sys.stderr.write(f"[portal-villode] {msg}\n")
    sys.stderr.flush()


def variant_get(options: dict, key: str, default=None):
    if key not in options:
        return default
    v = options[key]
    try:
        return v.unpack()
    except Exception:
        return v


def filters_to_csv(options: dict) -> str:
    filters = variant_get(options, "filters")
    if not filters:
        return "*"
    patterns: list[str] = []
    try:
        for _label, rules in filters:
            for _typ, pat in rules:
                if isinstance(pat, str):
                    if pat.startswith("*."):
                        patterns.append(pat[2:])
                    elif pat == "*":
                        return "*"
                    else:
                        patterns.append(pat.lstrip("*."))
    except Exception as e:
        log(f"filter parse: {e}")
        return "*"
    return ",".join(patterns) if patterns else "*"


def current_folder(options: dict) -> str:
    raw = variant_get(options, "current_folder")
    if raw is None:
        return str(Path.home())
    if isinstance(raw, (bytes, bytearray)):
        s = bytes(raw).split(b"\0", 1)[0].decode("utf-8", "replace")
        return s or str(Path.home())
    if isinstance(raw, str):
        return raw
    return str(Path.home())


def current_name(options: dict) -> str:
    name = variant_get(options, "current_name")
    return str(name) if name else "untitled"


def ensure_uri(s: str) -> str:
    s = s.strip()
    if not s:
        return s
    if s.startswith("file://"):
        return s
    if s.startswith("/"):
        return "file://" + urllib.parse.quote(s, safe="/")
    return s


def wait_result(path: Path, timeout: float = TIMEOUT_SEC) -> tuple[int, list[str]]:
    deadline = time.time() + timeout
    while time.time() < deadline:
        if path.exists() and path.stat().st_size > 0:
            try:
                text = path.read_text(encoding="utf-8", errors="replace")
            except OSError:
                time.sleep(0.05)
                continue
            lines = text.splitlines()
            if not lines:
                time.sleep(0.05)
                continue
            status = lines[0].strip()
            if status == "CANCEL":
                return 1, []
            if status == "OK":
                uris = [ensure_uri(x) for x in lines[1:] if x.strip()]
                return (0 if uris else 1), uris
            if status.startswith("file:") or status.startswith("/"):
                uris = [ensure_uri(x) for x in lines if x.strip()]
                return (0 if uris else 1), uris
        time.sleep(0.08)
    return 2, []


def launch_picker(mode: str, title: str, options: dict) -> tuple[int, list[str]]:
    fd, tmp = tempfile.mkstemp(prefix="villode-fc-", suffix=".txt")
    os.close(fd)
    result = Path(tmp)
    req_fd, req_tmp = tempfile.mkstemp(prefix="villode-fc-req-", suffix=".json")
    os.close(req_fd)
    req_path = Path(req_tmp)
    try:
        result.write_text("", encoding="utf-8")
        folder = current_folder(options)
        filt = filters_to_csv(options)
        filters = ["*"] if filt == "*" else [x for x in filt.split(",") if x]
        multiple = bool(variant_get(options, "multiple", False))
        directory = bool(variant_get(options, "directory", False))

        if mode == "save":
            req = {
                "mode": "save",
                "title": title or "保存文件",
                "resultFile": str(result),
                "filters": filters,
                "startDir": folder,
                "suggestedName": current_name(options),
            }
        elif directory:
            req = {
                "mode": "folder",
                "title": title or "选择文件夹",
                "resultFile": str(result),
                "startDir": folder,
                "acceptDirectories": True,
            }
        else:
            req = {
                "mode": "open",
                "title": title or "打开文件",
                "resultFile": str(result),
                "filters": filters,
                "startDir": folder,
                "multiple": multiple,
            }

        req_path.write_text(json.dumps(req, ensure_ascii=False), encoding="utf-8")
        cmd = [
            "qs",
            "-c",
            "caelestia",
            "ipc",
            "call",
            "filechooser",
            "request",
            str(req_path),
        ]
        log(f"launch request {req_path} body={req!r}")
        try:
            subprocess.Popen(
                cmd,
                stdout=subprocess.DEVNULL,
                stderr=subprocess.DEVNULL,
                start_new_session=True,
                env=os.environ.copy(),
            )
        except Exception as e:
            log(f"qs spawn failed: {e}")
            return 2, []

        return wait_result(result)
    finally:
        try:
            result.unlink(missing_ok=True)
        except Exception:
            pass
        try:
            req_path.unlink(missing_ok=True)
        except Exception:
            pass


class FileChooserService:
    def __init__(self):
        self._lock = threading.Lock()

    def handle(self, method: str, title: str, options: dict, invocation: Gio.DBusMethodInvocation) -> None:
        mode = "save" if method in ("SaveFile", "SaveFiles") else "open"
        log(f"{method} title={title!r}")

        def worker():
            with self._lock:
                response, uris = launch_picker(mode, title, options or {})
            results = {}
            if response == 0 and uris:
                results["uris"] = GLib.Variant("as", uris)
                results["choices"] = GLib.Variant("a(ss)", [])
            try:
                invocation.return_value(GLib.Variant("(ua{sv})", (response, results)))
            except Exception as e:
                log(f"return_value failed: {e}")
                try:
                    invocation.return_dbus_error(
                        "org.freedesktop.DBus.Error.Failed", str(e)
                    )
                except Exception:
                    pass

        threading.Thread(target=worker, daemon=True).start()


def main() -> int:
    signal.signal(signal.SIGINT, signal.SIG_DFL)
    loop = GLib.MainLoop()
    conn = Gio.bus_get_sync(Gio.BusType.SESSION, None)
    node = Gio.DBusNodeInfo.new_for_xml(INTROSPECTION_XML)
    iface_info = node.interfaces[0]
    svc = FileChooserService()

    def on_method_call(
        connection, sender, object_path, interface_name, method_name, parameters, invocation
    ):
        args = parameters.unpack()
        title = args[3] if len(args) > 3 else ""
        options = args[4] if len(args) > 4 else {}
        if method_name in ("OpenFile", "SaveFile", "SaveFiles"):
            svc.handle(method_name, title, options, invocation)
        else:
            invocation.return_error_literal(
                Gio.dbus_error_quark(),
                Gio.DBusError.UNKNOWN_METHOD,
                f"Unknown method {method_name}",
            )

    reg_id = conn.register_object(OBJECT_PATH, iface_info, on_method_call, None, None)
    log(f"registered object id={reg_id}")

    owner_id = Gio.bus_own_name_on_connection(
        conn,
        BUS_NAME,
        Gio.BusNameOwnerFlags.NONE,
        None,
        None,
    )
    log(f"own_name id={owner_id} name={BUS_NAME}")

    try:
        loop.run()
    finally:
        if owner_id:
            Gio.bus_unown_name(owner_id)
        if reg_id:
            conn.unregister_object(reg_id)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
