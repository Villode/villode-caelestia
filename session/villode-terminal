#!/usr/bin/env python3
"""Launch the terminal selected in Caelestia's default-app settings."""

import json
import os
import shutil
from pathlib import Path


def configured_terminal():
    config_home = Path(os.environ.get("XDG_CONFIG_HOME", Path.home() / ".config"))
    try:
        data = json.loads((config_home / "caelestia" / "shell.json").read_text())
        command = data["general"]["apps"]["terminal"]
        if (
            isinstance(command, list)
            and command
            and all(isinstance(argument, str) and argument for argument in command)
            and shutil.which(command[0])
        ):
            return command
    except (FileNotFoundError, KeyError, OSError, TypeError, ValueError, json.JSONDecodeError):
        pass

    for candidate in ("alacritty", "foot", "kitty", "xterm"):
        if shutil.which(candidate):
            return [candidate]
    raise SystemExit("No supported terminal emulator is installed.")


os.execvp((command := configured_terminal())[0], command)
